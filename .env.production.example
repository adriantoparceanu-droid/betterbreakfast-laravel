APP_NAME="Better Breakfast"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://www.betterbreakfast.eu

DEPLOY_TOKEN=genereaza_cu_openssl_rand_hex_32

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_cpanel_db_name
DB_USERNAME=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.betterbreakfast.eu
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# hCaptcha — get keys from https://dashboard.hcaptcha.com
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

MAIL_MAILER=smtp
MAIL_HOST=mail.betterbreakfast.ro
MAIL_PORT=587
MAIL_USERNAME=no-reply@betterbreakfast.ro
MAIL_PASSWORD=your_mail_password
MAIL_FROM_ADDRESS="no-reply@betterbreakfast.ro"
MAIL_FROM_NAME="Better Breakfast"
